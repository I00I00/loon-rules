#!name=番茄小说净化 V4 登录保护版
#!desc=适配番茄小说 7.1.7：修复手机号登录被误伤问题，只精准拦截 ByteGecko 红包/福利/挂件资源。
#!author=ChatGPT
#!homepage=https://github.com/I00I00/loon-rules
#!icon=https://raw.githubusercontent.com/Orz-3/mini/master/Color/Book.png

[Rule]
# ==================================================
# 登录 / 验证码 / 风控 / 设备校验：必须直连，不能拦
# ==================================================
DOMAIN-SUFFIX,snssdk.com,DIRECT
DOMAIN-SUFFIX,mssdk.snssdk.com,DIRECT
DOMAIN-SUFFIX,log.snssdk.com,DIRECT
DOMAIN-SUFFIX,log-lq.snssdk.com,DIRECT
DOMAIN-SUFFIX,log-hl.snssdk.com,DIRECT
DOMAIN-SUFFIX,applog.snssdk.com,DIRECT
DOMAIN-SUFFIX,rtlog.snssdk.com,DIRECT
DOMAIN-SUFFIX,ibytedtos.com,DIRECT
DOMAIN-SUFFIX,zijieapi.com,DIRECT
DOMAIN-SUFFIX,bytedance.com,DIRECT
DOMAIN-SUFFIX,bytedance.net,DIRECT
DOMAIN-SUFFIX,bytegoofy.com,DIRECT
DOMAIN-SUFFIX,bytegecko.com,DIRECT
DOMAIN-SUFFIX,toutiao.com,DIRECT

# ==================================================
# 番茄小说 / 字节阅读相关直连
# ==================================================
DOMAIN-SUFFIX,fqnovel.com,DIRECT
DOMAIN-SUFFIX,fqnovelstatic.com,DIRECT
DOMAIN-SUFFIX,fanqienovel.com,DIRECT
DOMAIN-SUFFIX,novelfm.com,DIRECT
DOMAIN-SUFFIX,novel.snssdk.com,DIRECT
DOMAIN-SUFFIX,reading.snssdk.com,DIRECT
DOMAIN-SUFFIX,is.snssdk.com,DIRECT
DOMAIN-SUFFIX,tp-pay.snssdk.com,DIRECT
DOMAIN-SUFFIX,vas-lf-x.snssdk.com,DIRECT
DOMAIN-SUFFIX,byteimg.com,DIRECT
DOMAIN-SUFFIX,bytecdn.cn,DIRECT
DOMAIN-SUFFIX,pstatp.com,DIRECT
DOMAIN-SUFFIX,zjcdn.com,DIRECT

# ==================================================
# 只保留明确广告 SDK 域名拦截
# 不再拦 mssdk / applog / log / rtlog，避免影响登录
# ==================================================
DOMAIN-SUFFIX,pangolin-sdk-toutiao.com,REJECT
DOMAIN-SUFFIX,pglstatp-toutiao.com,REJECT
DOMAIN-SUFFIX,ad.toutiao.com,REJECT
DOMAIN-SUFFIX,ads.toutiao.com,REJECT

[Rewrite]
# ==================================================
# 精准拦截 ByteGecko 下发的福利 / 红包 / 金币 / 挂件资源
# 来自你抓包里的真实资源：
# growth/luckycat
# gold_box_static_resource
# video_box_redpacket
# video_pendant_hide_reward_union
# ==================================================
^https?:\/\/[^\/]+\.bytegecko\.com\/obj\/byte-gurd-source\/growth\/luckycat\/.* reject-dict
^https?:\/\/[^\/]+\.bytegecko\.com\/obj\/ugflow-resource\/.*(redpacket|reward|pendant|welfare|coin|gold|box).*\.json.* reject-dict
^https?:\/\/[^\/]+\.bytegecko\.com\/obj\/.*(luckycat|gold_box|redpacket|reward|pendant|welfare|coin|bonus|task).*\.json.* reject-dict
^https?:\/\/.*(video_box_redpacket|video_pendant|redpacket_increase|gold_box_static|hide_reward_union).* reject-dict

[Script]
# 登录保护版：不再全量处理 snssdk / bytedance / toutiao
# 只处理番茄小说相关域名，降低登录和验证码误伤
http-response ^https?:\/\/.*(fqnovel|fanqienovel|novelfm|novel|reading).*\.(com|cn|net)\/.* script-path=https://raw.githubusercontent.com/I00I00/loon-rules/main/FanqieNovel_Cleaner.js, requires-body=true, timeout=15, tag=番茄小说_净化

[MITM]
hostname = *.fqnovel.com, *.fqnovelstatic.com, *.fanqienovel.com, *.novelfm.com, *.novel.snssdk.com, *.reading.snssdk.com, *.bytegecko.com
